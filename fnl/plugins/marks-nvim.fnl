{1 "https://github.com/chentoast/marks.nvim"
 :opts {:default_mappings false
        :mappings {:set "m"
                   :delete "dm"
                   :delete_line "dm-"
                   :delete_buf "dm<space>"
                   :next "]m"
                   :prev "[m"
                   :preview "m:"}}
 :event [:BufReadPost :BufNewFile]}
